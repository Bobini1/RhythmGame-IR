{
	"name": "RhythmGame-IR",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:server": "vitest run --environment=node",
		"test:db:up": "docker compose -f docker-compose.test.yml up -d",
		"test:db:down": "docker compose -f docker-compose.test.yml down",
		"local:db:up": "docker compose -f docker-compose.local.yml up -d",
		"local:db:down": "docker compose -f docker-compose.local.yml down",
		"create:page": "bun run scripts/create-page.js",
		"create:md": "bun run scripts/create-markdown.js",
		"create:api-controller": "bun run scripts/create-api-controller.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:reset": "drizzle-kit push --force --config scripts/reset-db.js"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.515.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/table-core": "^8.21.3",
		"@types/json-bigint": "^1.0.4",
		"@vitest/browser": "^3.2.4",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"super-sitemap": "^1.0.7",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.0.8",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^6.4.1",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^0.1.0"
	},
	"dependencies": {
		"@dicebear/collection": "^9.4.0",
		"@dicebear/core": "^9.4.0",
		"@types/bun": "^1.3.10",
		"better-auth": "^1.5.4",
		"drizzle-orm": "^0.44.7",
		"json-bigint": "^1.0.0",
		"mode-watcher": "^1.1.0",
		"postgres": "^3.4.8",
		"svelte-meta-tags": "^4.5.0",
		"svelte-turnstile": "^0.11.0",
		"sveltekit-i18n": "^2.4.2",
		"zod": "^4.3.6"
	}
}
